---
import AccountList from "../components/AccountList.astro";
import WeekendCalendar from "../components/WeekendCalendar.astro";
import db from "../db";
import BaseLayout from "../layouts/BaseLayout.astro";

const credential = await db.query.credentials.findFirst();
if (credential == null) return Astro.redirect("/setup");
---

<BaseLayout title="Porpoise">
    <h1>Porpoise</h1>

    <WeekendCalendar />

    <AccountList />

    <div>
        <a role="button" href="/accounts">
            Manage accounts (signing in required)
        </a>
    </div>
</BaseLayout>
